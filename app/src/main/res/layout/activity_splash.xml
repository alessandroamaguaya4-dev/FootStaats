<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="36dp"
    android:background="#0D131A">

    <!-- Logo flotante estilizado -->
    <ImageView
        android:layout_width="110dp"
        android:layout_height="110dp"
        android:src="@mipmap/ic_launcher"
        android:scaleType="centerInside"
        android:layout_marginBottom="24dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="FootStaats"
        android:textSize="38sp"
        android:fontFamily="sans-serif-black"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:letterSpacing="-0.02"
        android:layout_marginBottom="6dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tu rendimiento, tus estadísticas"
        android:textSize="15sp"
        android:fontFamily="sans-serif-medium"
        android:textColor="#8E9AA6"
        android:layout_marginBottom="64dp"/>

    <!-- Iniciar Sesión (Botón sólido premium) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnLogin"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Iniciar Sesión"
        android:textColor="#0D131A"
        android:textSize="16sp"
        android:textStyle="bold"
        app:backgroundTint="#FFFFFF"
        app:cornerRadius="16dp"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:layout_marginBottom="16dp"/>

    <!-- Registrarse (Botón con contorno minimalista traslúcido) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnRegistrarse"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Registrarse"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        app:backgroundTint="@android:color/transparent"
        app:strokeColor="#1E2630"
        app:strokeWidth="2dp"
        app:cornerRadius="16dp"
        android:insetTop="0dp"
        android:insetBottom="0dp"/>

</LinearLayout>